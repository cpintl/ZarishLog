{
  "formId": "DISP",
  "title": "Disposal Form",
  "fields": [
    { "name": "disposal_number", "type": "text", "auto": "sequence" },
    { "name": "disposal_date", "type": "date", "default": "now" },
    { "name": "warehouse_id", "type": "select", "source": "warehouses", "required": true },
    { "name": "disposal_method_code", "type": "select", "options": ["INCINERATION", "BURIAL", "CHEMICAL", "RECYCLING", "LANDFILL", "RETURN"] },
    { "name": "authorized_by", "type": "text" },
    { "name": "witness_by", "type": "text" },
    { "name": "reason", "type": "textarea" },
    { "name": "status", "type": "select", "options": ["draft", "active", "completed"] },
    {
      "name": "items",
      "type": "table",
      "columns": [
        { "name": "product_id", "type": "select", "source": "products", "required": true },
        { "name": "batch_number", "type": "text" },
        { "name": "quantity", "type": "number", "required": true },
        { "name": "unit_cost", "type": "number" },
        { "name": "notes", "type": "textarea" }
      ]
    }
  ]
}
