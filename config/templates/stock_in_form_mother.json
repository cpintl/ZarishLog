{
  "formId": "STK-IN-M",
  "title": "Stock In — Mother Facility",
  "description": "For large/central facilities with full receiving capability",
  "fields": [
    { "name": "warehouseId", "type": "select", "source": "warehouses", "required": true },
    { "name": "supplierName", "type": "text", "required": false },
    { "name": "donorName", "type": "text", "required": false },
    { "name": "grnNumber", "type": "text", "required": true, "auto": "sequence" },
    { "name": "poReference", "type": "text", "required": false },
    { "name": "receivedAt", "type": "datetime", "required": true, "default": "now" },
    { "name": "receivedBy", "type": "user", "required": true, "auto": "currentUser" },
    { "name": "verifiedBy", "type": "user", "required": false },
    { "name": "programId", "type": "select", "source": "programs", "required": false },
    { "name": "justificationCode", "type": "select", "source": "justification_codes", "required": false },
    {
      "name": "lines",
      "type": "table",
      "columns": [
        { "name": "productId", "type": "select", "source": "products", "required": true },
        { "name": "batchNo", "type": "text", "requiredIf": "product.batchTracked" },
        { "name": "serialNo", "type": "text", "requiredIf": "product.serialTracked" },
        { "name": "expiryDate", "type": "date", "requiredIf": "product.expiryTracked" },
        { "name": "quantityReceived", "type": "number", "required": true },
        { "name": "unitCost", "type": "number" },
        { "name": "condition", "type": "select", "options": ["Good", "Damaged", "Expired", "Partial"] },
        { "name": "locationId", "type": "select", "source": "locations", "required": false }
      ]
    },
    { "name": "remarks", "type": "textarea" },
    { "name": "documents", "type": "file-upload", "multiple": true }
  ]
}
