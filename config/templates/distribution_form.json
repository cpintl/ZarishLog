{
  "formId": "DIST",
  "title": "Distribution / Delivery Form",
  "fields": [
    { "name": "distribution_number", "type": "text", "auto": "sequence" },
    { "name": "distribution_date", "type": "date", "default": "now" },
    { "name": "program_id", "type": "select", "source": "programs", "required": true },
    { "name": "org_level_id", "type": "select", "source": "org_levels", "required": true },
    { "name": "location", "type": "text" },
    { "name": "beneficiary_count", "type": "number" },
    { "name": "status", "type": "select", "options": ["draft", "active", "completed", "cancelled"] },
    { "name": "notes", "type": "textarea" },
    {
      "name": "items",
      "type": "table",
      "columns": [
        { "name": "sku", "type": "select", "source": "products", "required": true },
        { "name": "quantity_planned", "type": "number", "required": true },
        { "name": "batch_number", "type": "text" }
      ]
    }
  ]
}
