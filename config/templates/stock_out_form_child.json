{
  "formId": "STK-OUT-C",
  "title": "Stock Out — Child Facility",
  "description": "Simplified issue form for small facilities and field posts",
  "fields": [
    { "name": "warehouseId", "type": "select", "source": "warehouses", "required": true },
    { "name": "issueNumber", "type": "text", "required": true, "auto": "sequence" },
    { "name": "issuedAt", "type": "datetime", "required": true, "default": "now" },
    { "name": "issuedTo", "type": "text", "required": true, "note": "Person or receiving facility name" },
    { "name": "approvedBy", "type": "user", "required": false },
    {
      "name": "lines",
      "type": "table",
      "columns": [
        { "name": "productId", "type": "select", "source": "products", "required": true },
        { "name": "quantity", "type": "number", "required": true }
      ]
    },
    { "name": "remarks", "type": "textarea" }
  ]
}
