{
  "name": "zarishlog",
  "private": true,
  "version": "0.1.0",
  "description": "ZarishLog — Unified Humanitarian Logistics, Supply Chain & Asset Management Platform",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @zarishlog/data-models db:generate",
    "db:migrate": "pnpm --filter @zarishlog/data-models db:migrate",
    "db:seed": "pnpm --filter @zarishlog/data-models db:seed",
    "db:studio": "pnpm --filter @zarishlog/data-models db:studio"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "prettier": "^3.3.3",
    "eslint": "^9.13.0"
  }
}
