# ─── Database ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://zarishlog:zarishlog_dev_password@localhost:5432/zarishlog?schema=public"

# ─── Redis (background jobs, BullMQ) ──────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Object storage (MinIO locally / R2 or S3 in production) ─────────
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="zarishlog"
S3_SECRET_KEY="zarishlog_dev_password"
S3_BUCKET="zarishlog-dev"
S3_REGION="us-east-1"

# ─── Auth (Keycloak locally / Supabase Auth in managed deployments) ──
OIDC_ISSUER_URL="http://localhost:8080/realms/zarishlog"
OIDC_CLIENT_ID="zarishlog-api"
OIDC_CLIENT_SECRET="changeme"
JWT_AUDIENCE="zarishlog-api"

# ─── API ───────────────────────────────────────────────────────────────
API_PORT=4000
API_URL="http://localhost:4000"

# ─── Web ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"
WEB_PORT=3000

# ─── Email (Resend free tier) ─────────────────────────────────────────
RESEND_API_KEY=""
NOTIFICATION_FROM_EMAIL="noreply@zarishlog.org"

# ─── Localization ──────────────────────────────────────────────────────
DEFAULT_TIMEZONE="Asia/Dhaka"   # GMT+6
DEFAULT_DATE_FORMAT="DD MMMM YYYY"
DEFAULT_TIME_FORMAT="hh:mm A"
