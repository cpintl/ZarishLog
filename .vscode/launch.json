{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach to Chrome",
      "port": 9222,
      "request": "attach",
      "type": "chrome",
      "webRoot": "${workspaceFolder}"
    },

    {
      "name": "Sandbox: Start",
      "type": "node-terminal",
      "request": "launch",
      "command": "bash scripts/sandbox.sh start",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Sandbox: Stop",
      "type": "node-terminal",
      "request": "launch",
      "command": "bash scripts/sandbox.sh stop",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Sandbox: Reset",
      "type": "node-terminal",
      "request": "launch",
      "command": "bash scripts/sandbox.sh reset",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Sandbox: Start",
      "type": "node-terminal",
      "request": "launch",
      "command": "bash ./scripts/sandbox.sh start",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "API Server (Go)",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/apps/api/cmd/api",
      "cwd": "${workspaceFolder}/apps/api",
      "envFile": "${workspaceFolder}/.env",
      "args": [],
      "showLog": true
    },
    {
      "name": "Web (Next.js)",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev",
      "cwd": "${workspaceFolder}/apps/web"
    },
    {
      "name": "Go Test (Package)",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/apps/api/${relativeFileDirname}",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Go Test All",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/apps/api/...",
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
