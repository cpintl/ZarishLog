{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API Server (Go)",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/apps/api/cmd/api",
      "cwd": "${workspaceFolder}/apps/api",
      "envFile": "${workspaceFolder}/.env",
      "args": [],
      "showLog": true
    },
    {
      "name": "Web (Next.js)",
      "type": "node-terminal",
      "request": "launch",
      "command": "pnpm dev",
      "cwd": "${workspaceFolder}/apps/web"
    },
    {
      "name": "Go Test (Package)",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/apps/api/${relativeFileDirname}",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Go Test All",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/apps/api/...",
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
